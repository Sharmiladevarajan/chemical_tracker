# Copy to .env in this folder (backend/) and edit.

# --- Local PostgreSQL ---
# 1. Create DB: psql -U postgres -c "CREATE DATABASE chemical_tracker;"
# 2. Schema: psql -U postgres -d chemical_tracker -f ../db/01_create_tables.sql
# Prefer 127.0.0.1 on Windows if localhost resolves oddly.
# URL-encode password special chars (@ -> %40).
#
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@127.0.0.1:5432/chemical_tracker

# --- Supabase ---
# From Dashboard → Project Settings → Database → Connection string (URI).
# Use postgresql+psycopg2:// (not plain postgresql://).
# Default database name is postgres (not chemical_tracker); run ../db/*.sql in SQL editor once.
#
# Direct host (db.<ref>.supabase.co) is IPv6-only; the app resolves the IP for Windows/libpq.
# If port 5432 is blocked on your network, use the Session pooler host from the dashboard instead.
#
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
#
# On Render (IPv4): Supabase → Connect → pick "Session pooler" (NOT Direct) → copy URI.
# DATABASE_URL=postgresql+psycopg2://postgres.YOUR_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
# Or direct URI + SUPABASE_POOLER_REGION=ap-southeast-1 (auto-uses aws-1 pooler).

# CORS — comma-separated frontend origins (required for Vercel → Render)
# CORS_ORIGINS=https://chemicaltracker.vercel.app,http://localhost:3000
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
