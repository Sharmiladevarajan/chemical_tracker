# Copy this file to .env in the same folder (backend/) and edit.

# 1. Use the password you chose when installing PostgreSQL for user "postgres"
#    (or the password for whichever user you use).
# 2. Create the database once:  psql -U postgres -c "CREATE DATABASE chemical_tracker;"
# 3. Apply schema: psql -U postgres -d chemical_tracker -f ../db/01_create_tables.sql
#
# Prefer 127.0.0.1 if you see odd IPv6 (::1) connection issues on Windows.
#
# If your password contains @ # % etc., URL-encode it (e.g. @ -> %40).
#
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD_HERE@127.0.0.1:5432/chemical_tracker
